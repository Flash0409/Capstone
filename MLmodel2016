# HIGHER-ORDER CUMULANTS — computed in numpy at dataset build time
# ══════════════════════════════════════════════════════════════════════════════
def compute_hoc(iq_frame):
    """
    Compute 10 higher-order cumulant features from a single IQ frame.
    iq_frame : (128, 2) — normalised IQ signal

    WHY HOCs WORK:
      HOCs are provably discriminative for modulation order in a way that
      raw IQ samples cannot be for short windows. C40 = 0 for Gaussian noise,
      -2 for BPSK, -1 for QPSK, -0.5 for 16QAM, -0.36 for 64QAM — these
      theoretical values are distinct even at moderate SNR. The neural network
      learns to use them without needing to learn the underlying statistics
      from scratch, which is why HOC branches consistently give +2–4% on
      RML2016.10a benchmarks.

    Features:
      C20, C21 — 2nd order (power and mean square)
      C40, C41, C42 — 4th order cumulants (constellation shape)
      C60, C61, C62, C63 — 6th order cumulants (higher discrimination)

    Returns: (10,) float32 vector, clipped and normalised for stability
    """
    I  = iq_frame[:, 0].astype(np.complex64)
    Q  = iq_frame[:, 1].astype(np.complex64)
    z  = I + 1j * Q          # complex baseband signal (128,)
    N  = len(z)

    # Moments
    m10 = np.mean(z)
    m20 = np.mean(z**2)
    m21 = np.mean(np.abs(z)**2)
    m40 = np.mean(z**4)
    m41 = np.mean(np.abs(z)**2 * z**2)
    m42 = np.mean(np.abs(z)**4)
    m60 = np.mean(z**6)
    m61 = np.mean(np.abs(z)**2 * z**4)
    m62 = np.mean(np.abs(z)**4 * z**2)
    m63 = np.mean(np.abs(z)**6)

    # 2nd order cumulants
    C20 = m20 - m10**2
    C21 = m21 - np.abs(m10)**2

    # 4th order cumulants
    C40 = m40 - 3 * m20**2
    C41 = m41 - 3 * m20 * m21
    C42 = m42 - np.abs(m20)**2 - 2 * m21**2

    # 6th order cumulants
    C60 = m60 - 15 * m20 * m40 + 30 * m20**3
    C61 = m61 - 5 * m21 * m40 - 10 * m20 * m41 + 30 * m20**2 * m21
    C62 = m62 - 6 * m21 * m41 - np.abs(m20)**2 * m40 + 6 * m21**2 * m20 \
               + 4 * m20 * np.conj(m20) * m21 - 4 * m21**3   # simplified
    C63 = m63 - 9 * m42 * m21 + 12 * m21**3

    # Stack real parts (imaginary parts are noise at high SNR, real parts carry structure)
    features = np.array([
        C20.real, C21.real,
        C40.real, C41.real, C42.real,
        C60.real, C61.real, C62.real, C63.real,
        np.abs(C42),          # magnitude of C42 — key QAM16/64 discriminator
    ], dtype=np.float32)

    # Clip extremes and normalise — HOCs can blow up at very low SNR
    features = np.clip(features, -100.0, 100.0)
    norm = np.sqrt(np.sum(features**2)) + 1e-8
    return features / norm


