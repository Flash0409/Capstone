@tf.keras.utils.register_keras_serializable()
class ComplexConv1D(layers.Layer):
    """Complex-valued 1D conv. out_r = W_r*x_r - W_i*x_i, out_i = W_r*x_i + W_i*x_r"""
    def __init__(self, filters, kernel_size, padding='same',
                 strides=1, use_bias=False, **kwargs):
        super().__init__(**kwargs)
        self.filters = filters; self.kernel_size = kernel_size
        self.padding = padding; self.strides = strides; self.use_bias = use_bias

    def build(self, input_shape):
        self.conv_r = layers.Conv1D(self.filters, self.kernel_size,
                                     padding=self.padding, strides=self.strides,
                                     use_bias=self.use_bias)
        self.conv_i = layers.Conv1D(self.filters, self.kernel_size,
                                     padding=self.padding, strides=self.strides,
                                     use_bias=self.use_bias)
        super().build(input_shape)

    def call(self, x):
        mid = tf.shape(x)[-1] // 2
        x_r, x_i = x[..., :mid], x[..., mid:]
        return tf.concat([self.conv_r(x_r) - self.conv_i(x_i),
                          self.conv_r(x_i) + self.conv_i(x_r)], axis=-1)

    def get_config(self):
        cfg = super().get_config()
        cfg.update({"filters": self.filters, "kernel_size": self.kernel_size,
                    "padding": self.padding, "strides": self.strides,
                    "use_bias": self.use_bias})
        return cfg


@tf.keras.utils.register_keras_serializable()
class ComplexBatchNorm(layers.Layer):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.bn_r = layers.BatchNormalization()
        self.bn_i = layers.BatchNormalization()

    def call(self, x, training=None):
        mid = tf.shape(x)[-1] // 2
        return tf.concat([self.bn_r(x[..., :mid], training=training),
                          self.bn_i(x[..., mid:], training=training)], axis=-1)

    def get_config(self):
        return super().get_config()


def complex_res_block(x, filters, kernel_size=7):
    shortcut = x
    out = layers.Activation('gelu')(ComplexBatchNorm()(ComplexConv1D(filters, kernel_size)(x)))
    out = ComplexBatchNorm()(ComplexConv1D(filters, kernel_size)(out))
    if x.shape[-1] != filters * 2:
        shortcut = ComplexBatchNorm()(ComplexConv1D(filters, 1)(x))
    return layers.Activation('gelu')(layers.Add()([out, shortcut]))


def real_res_block(x, filters, kernel_size=7):
    shortcut = x
    out = layers.Activation('gelu')(layers.BatchNormalization()(
        layers.Conv1D(filters, kernel_size, padding='same', use_bias=False)(x)))
    out = layers.BatchNormalization()(
        layers.Conv1D(filters, kernel_size, padding='same', use_bias=False)(out))
    if x.shape[-1] != filters:
        shortcut = layers.BatchNormalization()(
            layers.Conv1D(filters, 1, padding='same', use_bias=False)(x))
    return layers.Activation('gelu')(layers.Add()([out, shortcut]))


@tf.keras.utils.register_keras_serializable()
class CrossStreamAttention(layers.Layer):
    """
    CONTRIBUTION 1: Bidirectional cross-attention between IQ and AP streams.
    IQ_out = IQ + MHA(query=IQ, key=AP, value=AP)
    AP_out = AP + MHA(query=AP, key=IQ, value=IQ)
    Applied after each ResNet stage — not just at final concatenation.
    """
    def __init__(self, num_heads=4, key_dim=16, dropout=0.1, **kwargs):
        super().__init__(**kwargs)
        self.num_heads = num_heads
        self.key_dim   = key_dim
        self.dropout_r = dropout

    def build(self, input_shape):
        self.attn_iq  = layers.MultiHeadAttention(
            num_heads=self.num_heads, key_dim=self.key_dim, dropout=self.dropout_r)
        self.norm_iq  = layers.LayerNormalization(epsilon=1e-6)
        self.attn_ap  = layers.MultiHeadAttention(
            num_heads=self.num_heads, key_dim=self.key_dim, dropout=self.dropout_r)
        self.norm_ap  = layers.LayerNormalization(epsilon=1e-6)
        super().build(input_shape)

    def call(self, inputs, training=None):
        iq, ap = inputs
        iq_out = iq + self.attn_iq(
            query=self.norm_iq(iq), key=ap, value=ap, training=training)
        ap_out = ap + self.attn_ap(
            query=self.norm_ap(ap), key=iq, value=iq, training=training)
        return iq_out, ap_out

    def get_config(self):
        cfg = super().get_config()
        cfg.update({"num_heads": self.num_heads, "key_dim": self.key_dim,
                    "dropout": self.dropout_r})
        return cfg


def build_snr_estimator(iq_input):
    """
    CONTRIBUTION 2: Lightweight SNR estimator head.
    Produces α ∈ [0,1] gating fusion: fused = (1-α)·IQ + α·AP.
    Trained with auxiliary MSE loss on normalised true SNR.
    """
    x = layers.Activation('relu')(layers.BatchNormalization()(
        layers.Conv1D(16, 7, padding='same', use_bias=False)(iq_input)))
    x = layers.Activation('relu')(layers.BatchNormalization()(
        layers.Conv1D(16, 5, padding='same', use_bias=False)(x)))
    x = layers.GlobalAveragePooling1D()(x)
    x = layers.Dense(32, activation='relu')(x)
    snr_pred_norm = layers.Dense(1, activation='sigmoid', name='snr_pred')(x)
    return snr_pred_norm   # also used as α gate


@tf.keras.utils.register_keras_serializable()
class SNRAdaptiveGate(layers.Layer):
    """fused = (1-α)·proj(IQ) + α·proj(AP)"""
    def __init__(self, out_dim, **kwargs):
        super().__init__(**kwargs)
        self.out_dim    = out_dim
        self.proj_iq    = layers.Dense(out_dim, use_bias=False)
        self.proj_ap    = layers.Dense(out_dim, use_bias=False)
        self.layer_norm = layers.LayerNormalization(epsilon=1e-6)

    def call(self, inputs):
        iq, ap, alpha = inputs
        alpha_t = alpha[:, None, :]              # (B,1,1) → broadcasts over (B,T,C)
        fused   = (1.0 - alpha_t) * self.proj_iq(iq) + alpha_t * self.proj_ap(ap)
        return self.layer_norm(fused)

    def get_config(self):
        cfg = super().get_config()
        cfg.update({"out_dim": self.out_dim})
        return cfg


def channel_attention(x, reduction=4):
    ch   = x.shape[-1]
    gap  = layers.GlobalAveragePooling1D()(x)
    attn = layers.Dense(ch // reduction, activation='relu')(gap)
    attn = layers.Dense(ch, activation='sigmoid')(attn)
    return x * attn[:, None, :]


@tf.keras.utils.register_keras_serializable()
class LearnedPositionEmbedding(layers.Layer):
    def __init__(self, max_len=128, **kwargs):
        super().__init__(**kwargs)
        self.max_len = max_len

    def build(self, input_shape):
        self.pos_emb = self.add_weight(
            name='pos_emb', shape=(1, self.max_len, input_shape[-1]),
            initializer='zeros', trainable=True)

    def call(self, x):
        return x + self.pos_emb[:, :tf.shape(x)[1], :]

    def get_config(self):
        cfg = super().get_config()
        cfg.update({"max_len": self.max_len})
        return cfg


@tf.keras.utils.register_keras_serializable()
class WarmupCosineDecay(keras.optimizers.schedules.LearningRateSchedule):
    def __init__(self, warmup_steps, total_steps, peak_lr=3e-4, min_lr=1e-6, **kwargs):
        super().__init__(**kwargs)
        self.warmup_steps = float(warmup_steps)
        self.total_steps  = float(total_steps)
        self.peak_lr      = float(peak_lr)
        self.min_lr       = float(min_lr)

    def __call__(self, step):
        step     = tf.cast(step, tf.float32)
        warmup   = self.peak_lr * step / self.warmup_steps
        progress = (step - self.warmup_steps) / (self.total_steps - self.warmup_steps)
        cosine   = self.min_lr + (self.peak_lr - self.min_lr) * 0.5 * (
                   1.0 + tf.cos(np.pi * tf.minimum(progress, 1.0)))
        return tf.where(step < self.warmup_steps, warmup, cosine)

    def get_config(self):
        return {"warmup_steps": self.warmup_steps, "total_steps": self.total_steps,
                "peak_lr": self.peak_lr, "min_lr": self.min_lr}


# ══════════════════════════════════════════════════════════════════════════════
# MAIN MODEL — v7
# ══════════════════════════════════════════════════════════════════════════════
def build_model_v7(n_classes=11, hoc_dim=10):
    iq_input  = keras.Input(shape=(128, 2),  name='iq_input')
    ap_input  = keras.Input(shape=(128, 2),  name='ap_input')
    hoc_input = keras.Input(shape=(hoc_dim,), name='hoc_input')

    # ── IQ stream ─────────────────────────────────────────────────────────────
    iq = layers.Dropout(0.05)(layers.Activation('gelu')(
         ComplexBatchNorm(name='iq_stem_bn')(ComplexConv1D(32, 7, name='iq_stem')(iq_input))))

    # ── AP stream ─────────────────────────────────────────────────────────────
    ap = layers.Dropout(0.05)(layers.Activation('gelu')(
         layers.BatchNormalization()(
         layers.Conv1D(32, 7, padding='same', use_bias=False, name='ap_stem')(ap_input))))

    # ── Stage 1 ───────────────────────────────────────────────────────────────
    iq = complex_res_block(iq, 32, 7)
    ap = real_res_block(ap, 32, 7)
    iq, ap = CrossStreamAttention(num_heads=4, key_dim=16, name='cross_attn_1')([iq, ap])

    # ── Stage 2 ───────────────────────────────────────────────────────────────
    iq = complex_res_block(iq, 48, 5)
    ap = real_res_block(ap, 48, 5)
    iq, ap = CrossStreamAttention(num_heads=4, key_dim=24, name='cross_attn_2')([iq, ap])

    # ── Stage 3 ───────────────────────────────────────────────────────────────
    iq = complex_res_block(iq, 48, 5)
    ap = real_res_block(ap, 64, 5)
    iq, ap = CrossStreamAttention(num_heads=4, key_dim=24, name='cross_attn_3')([iq, ap])

    iq = layers.Dropout(0.1)(iq)
    ap = layers.Dropout(0.1)(ap)

    # ── SNR-adaptive gate (CONTRIBUTION 2) ────────────────────────────────────
    snr_pred_norm = build_snr_estimator(iq_input)
    fused = SNRAdaptiveGate(out_dim=160, name='snr_gate')([iq, ap, snr_pred_norm])

    # ── Temporal modelling ────────────────────────────────────────────────────
    fused = LearnedPositionEmbedding(max_len=128, name='pos_emb')(fused)
    fused = layers.Bidirectional(
        layers.LSTM(128, return_sequences=True, dropout=0.1),
        name='bilstm')(fused)                          # (B, 128, 256)
    fused = channel_attention(fused, reduction=4)
    fused = layers.GlobalAveragePooling1D()(fused)     # (B, 256)
    fused = layers.LayerNormalization(epsilon=1e-6)(fused)

    # ── HOC branch (CONTRIBUTION 3) ───────────────────────────────────────────
    # Small MLP on the 10 HOC features, then fused with BiLSTM output
    # Injected AFTER temporal modelling so HOC doesn't interfere with
    # the sequence-level learning — it's a complementary statistical branch
    hoc = layers.Dense(32, activation='gelu',
                       kernel_regularizer=keras.regularizers.l2(1e-4))(hoc_input)
    hoc = layers.BatchNormalization()(hoc)
    hoc = layers.Dropout(0.2)(hoc)
    hoc = layers.Dense(64, activation='gelu',
                       kernel_regularizer=keras.regularizers.l2(1e-4))(hoc)
    hoc = layers.BatchNormalization()(hoc)
    hoc = layers.Dropout(0.2)(hoc)

    # Concatenate deep features (256) + HOC features (64) = 320
    combined = layers.Concatenate(name='deep_hoc_fusion')([fused, hoc])

    # ── Classifier head ───────────────────────────────────────────────────────
    combined = layers.Dense(128, activation='gelu',
                             kernel_regularizer=keras.regularizers.l2(5e-5))(combined)
    combined = layers.Dropout(0.3)(combined)
    cls_out  = layers.Dense(n_classes, activation='softmax',
                             dtype='float32', name='output')(combined)

    return keras.Model(
        [iq_input, ap_input, hoc_input],
        [cls_out, snr_pred_norm],
        name='RadioML_v7')


