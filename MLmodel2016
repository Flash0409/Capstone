@tf.keras.utils.register_keras_serializable()
class SoftArgmaxAccuracy(tf.keras.metrics.Metric):
    """Consistent accuracy for soft (Mixup) and hard (val) labels."""
    def __init__(self, name='accuracy', **kwargs):
        super().__init__(name=name, **kwargs)
        self.total   = self.add_weight(name='total',   initializer='zeros')
        self.correct = self.add_weight(name='correct', initializer='zeros')

    def update_state(self, y_true, y_pred, sample_weight=None):
        y_pred_cls = tf.cast(tf.argmax(y_pred, axis=-1), tf.int32)
        if len(y_true.shape) == 2 and y_true.shape[-1] > 1:
            y_true_cls = tf.cast(tf.argmax(y_true, axis=-1), tf.int32)
        else:
            y_true_cls = tf.cast(tf.squeeze(y_true), tf.int32)
        correct = tf.cast(tf.equal(y_pred_cls, y_true_cls), tf.float32)
        if sample_weight is not None:
            sw = tf.cast(tf.squeeze(sample_weight), tf.float32)
            self.correct.assign_add(tf.reduce_sum(correct * sw))
            self.total.assign_add(tf.reduce_sum(sw))
        else:
            self.correct.assign_add(tf.reduce_sum(correct))
            self.total.assign_add(tf.cast(tf.shape(correct)[0], tf.float32))

    def result(self):
        return tf.math.divide_no_nan(self.correct, self.total)

    def reset_state(self):
        self.total.assign(0.0); self.correct.assign(0.0)

    def get_config(self):
        return super().get_config()


