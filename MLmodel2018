def make_train_ds(IQ, AP, HOC, y, snr_n, sw, bs, n_cls):
    y_oh = tf.keras.utils.to_categorical(y, num_classes=n_cls).astype(np.float32)
    ds   = tf.data.Dataset.from_tensor_slices((IQ, AP, HOC, y_oh, snr_n, sw))
    ds   = ds.shuffle(len(IQ), reshuffle_each_iteration=True).batch(bs, drop_remainder=True)

    def process(iq, ap, hoc, y_oh, snr_n, w):
        iq_a, ap_a = augment_iq_ap(iq, ap)
        iq_m, ap_m, hoc_m, y_m, sn_m = apply_soft_mixup(iq_a, ap_a, hoc, y_oh, snr_n)
        return (iq_m, ap_m, hoc_m), {'output': y_m, 'snr_pred': sn_m[:, None]}, w

    return ds.map(process, num_parallel_calls=tf.data.AUTOTUNE).prefetch(tf.data.AUTOTUNE)


def make_val_ds(IQ, AP, HOC, y, snr_n, bs):
    return (tf.data.Dataset
            .from_tensor_slices(((IQ, AP, HOC), {'output': y, 'snr_pred': snr_n[:, None]}))
            .batch(bs).prefetch(tf.data.AUTOTUNE))


