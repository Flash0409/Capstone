@tf.keras.utils.register_keras_serializable()
class SoftFocalLoss(tf.keras.losses.Loss):
    def __init__(self, gamma=2.0, **kwargs):
        super().__init__(**kwargs); self.gamma = gamma

    def call(self, y_true, y_pred):
        y_pred = tf.clip_by_value(y_pred, 1e-7, 1.0 - 1e-7)
        n_cls  = tf.shape(y_pred)[-1]
        if len(y_true.shape) == 1 or (len(y_true.shape) == 2 and y_true.shape[-1] == 1):
            y_true = tf.one_hot(tf.cast(tf.squeeze(y_true), tf.int32), n_cls)
        y_true = tf.cast(y_true, tf.float32)
        ce     = -tf.reduce_sum(y_true * tf.math.log(y_pred), axis=-1)
        p_t    = tf.reduce_sum(y_true * y_pred, axis=-1)
        return tf.reduce_mean(tf.pow(1.0 - p_t, self.gamma) * ce)

    def get_config(self):
        cfg = super().get_config(); cfg.update({"gamma": self.gamma}); return cfg


# ══════════════════════════════════════════════════════════════════════════════
# HOC FEATURES
# ══════════════════════════════════════════════════════════════════════════════
def compute_hoc(iq_frame):
    """10 HOC features from (1024, 2) frame. 1024 samples → ~8x better C42 vs 128."""
    I = iq_frame[:, 0].astype(np.complex64)
    Q = iq_frame[:, 1].astype(np.complex64)
    z = I + 1j * Q

    m10 = np.mean(z);         m20 = np.mean(z**2);       m21 = np.mean(np.abs(z)**2)
    m40 = np.mean(z**4);      m41 = np.mean(np.abs(z)**2 * z**2)
    m42 = np.mean(np.abs(z)**4)
    m60 = np.mean(z**6);      m61 = np.mean(np.abs(z)**2 * z**4)
    m62 = np.mean(np.abs(z)**4 * z**2); m63 = np.mean(np.abs(z)**6)

    C20 = m20 - m10**2;       C21 = m21 - np.abs(m10)**2
    C40 = m40 - 3*m20**2;     C41 = m41 - 3*m20*m21
    C42 = m42 - np.abs(m20)**2 - 2*m21**2
    C60 = m60 - 15*m20*m40 + 30*m20**3
    C61 = m61 - 5*m21*m40 - 10*m20*m41 + 30*m20**2*m21
    C62 = m62 - 6*m21*m41 - np.abs(m20)**2*m40 + \
               6*m21**2*m20 + 4*m20*np.conj(m20)*m21 - 4*m21**3
    C63 = m63 - 9*m42*m21 + 12*m21**3

    features = np.array([
        C20.real, C21.real, C40.real, C41.real, C42.real,
        C60.real, C61.real, C62.real, C63.real, np.abs(C42),
    ], dtype=np.float32)
    features = np.clip(features, -100.0, 100.0)
    return features / (np.sqrt(np.sum(features**2)) + 1e-8)


# ══════════════════════════════════════════════════════════════════════════════
# PREPROCESSING
# ══════════════════════════════════════════════════════════════════════════════
def preprocess_frame(raw_frame):
    """raw_frame: (1024, 2) — 2018 dataset is already (T,2) format."""
    I   = raw_frame[:, 0].astype(np.float32)
    Q   = raw_frame[:, 1].astype(np.float32)
    rms = np.sqrt(np.mean(I**2 + Q**2))
    if rms > 1e-8:
        I, Q = I / rms, Q / rms
    iq  = np.stack([I, Q], axis=-1)
    ap  = np.stack([np.sqrt(I**2 + Q**2), np.arctan2(Q, I)], axis=-1)
    hoc = compute_hoc(iq)
    return iq, ap, hoc


# ══════════════════════════════════════════════════════════════════════════════
# AUGMENTATION
# ══════════════════════════════════════════════════════════════════════════════
def augment_iq_ap(iq, ap):
    theta  = tf.random.uniform(shape=(tf.shape(iq)[0],), minval=0.0, maxval=2*np.pi)
    cos_t  = tf.cos(theta)[:, None, None]
    sin_t  = tf.sin(theta)[:, None, None]
    scale  = tf.random.uniform(shape=(tf.shape(iq)[0], 1, 1), minval=0.9, maxval=1.1)
    I_rot  = (cos_t * iq[..., 0:1] - sin_t * iq[..., 1:2]) * scale
    Q_rot  = (sin_t * iq[..., 0:1] + cos_t * iq[..., 1:2]) * scale
    iq_aug = tf.concat([I_rot, Q_rot], axis=-1)
    ap_aug = tf.concat([
        tf.sqrt(tf.reduce_sum(iq_aug**2, axis=-1, keepdims=True)),
        tf.atan2(iq_aug[..., 1:2], iq_aug[..., 0:1])
    ], axis=-1)
    return iq_aug, ap_aug


def apply_soft_mixup(iq, ap, hoc, y_oh, snr):
    batch_size = tf.shape(iq)[0]
    lam   = tf.random.uniform(shape=(batch_size,), minval=0.5, maxval=1.0)
    perm  = tf.random.shuffle(tf.range(batch_size))
    iq2   = tf.gather(iq, perm);   ap2  = tf.gather(ap, perm)
    hoc2  = tf.gather(hoc, perm);  y2   = tf.gather(y_oh, perm)
    snr2  = tf.gather(snr, perm)
    apply = tf.cast(tf.random.uniform(shape=(batch_size,)) < 0.30, tf.float32)
    lam_e = lam * apply + (1.0 - apply)
    lam_x = lam_e[:, None, None];  lam_f = lam_e[:, None]
    iq_m  = lam_x*iq  + (1.0-lam_x)*iq2
    ap_m  = lam_x*ap  + (1.0-lam_x)*ap2
    hoc_m = lam_f*hoc + (1.0-lam_f)*hoc2
    y_m   = lam_f*tf.cast(y_oh,tf.float32) + (1.0-lam_f)*tf.cast(y2,tf.float32)
    snr_m = lam_e*tf.cast(snr,tf.float32)  + (1.0-lam_e)*tf.cast(snr2,tf.float32)
    return iq_m, ap_m, hoc_m, y_m, snr_m


