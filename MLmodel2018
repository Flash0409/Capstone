@tf.keras.utils.register_keras_serializable()
class ComplexConv1D(layers.Layer):
    def __init__(self, filters, kernel_size, padding='same',
                 strides=1, use_bias=False, **kwargs):
        super().__init__(**kwargs)
        self.filters=filters; self.kernel_size=kernel_size
        self.padding=padding; self.strides=strides; self.use_bias=use_bias

    def build(self, s):
        self.conv_r=layers.Conv1D(self.filters,self.kernel_size,padding=self.padding,
                                   strides=self.strides,use_bias=self.use_bias)
        self.conv_i=layers.Conv1D(self.filters,self.kernel_size,padding=self.padding,
                                   strides=self.strides,use_bias=self.use_bias)
        super().build(s)

    def call(self, x):
        mid=tf.shape(x)[-1]//2; xr,xi=x[...,:mid],x[...,mid:]
        return tf.concat([self.conv_r(xr)-self.conv_i(xi),
                          self.conv_r(xi)+self.conv_i(xr)],axis=-1)

    def get_config(self):
        cfg=super().get_config()
        cfg.update({"filters":self.filters,"kernel_size":self.kernel_size,
                    "padding":self.padding,"strides":self.strides,"use_bias":self.use_bias})
        return cfg


@tf.keras.utils.register_keras_serializable()
class ComplexBatchNorm(layers.Layer):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.bn_r=layers.BatchNormalization(); self.bn_i=layers.BatchNormalization()

    def call(self, x, training=None):
        mid=tf.shape(x)[-1]//2
        return tf.concat([self.bn_r(x[...,:mid],training=training),
                          self.bn_i(x[...,mid:],training=training)],axis=-1)

    def get_config(self): return super().get_config()


def complex_res_block(x, filters, ks=7):
    sc=x
    out=layers.Activation('gelu')(ComplexBatchNorm()(ComplexConv1D(filters,ks)(x)))
    out=ComplexBatchNorm()(ComplexConv1D(filters,ks)(out))
    if x.shape[-1]!=filters*2: sc=ComplexBatchNorm()(ComplexConv1D(filters,1)(x))
    return layers.Activation('gelu')(layers.Add()([out,sc]))


def real_res_block(x, filters, ks=7):
    sc=x
    out=layers.Activation('gelu')(layers.BatchNormalization()(
        layers.Conv1D(filters,ks,padding='same',use_bias=False)(x)))
    out=layers.BatchNormalization()(
        layers.Conv1D(filters,ks,padding='same',use_bias=False)(out))
    if x.shape[-1]!=filters:
        sc=layers.BatchNormalization()(
           layers.Conv1D(filters,1,padding='same',use_bias=False)(x))
    return layers.Activation('gelu')(layers.Add()([out,sc]))


@tf.keras.utils.register_keras_serializable()
class CrossStreamAttention(layers.Layer):
    """
    Cross-attention between IQ and AP streams.
    Must operate on compressed (128-step) sequences — NOT 1024-step.
    1024-step attention = [B,4,1024,1024] = OOM. 128-step = [B,4,128,128] = fine.
    """
    def __init__(self, num_heads=4, key_dim=16, dropout=0.1, **kwargs):
        super().__init__(**kwargs)
        self.num_heads=num_heads; self.key_dim=key_dim; self.dropout_r=dropout

    def build(self, s):
        self.a_iq=layers.MultiHeadAttention(num_heads=self.num_heads,
                                             key_dim=self.key_dim,dropout=self.dropout_r)
        self.n_iq=layers.LayerNormalization(epsilon=1e-6)
        self.a_ap=layers.MultiHeadAttention(num_heads=self.num_heads,
                                             key_dim=self.key_dim,dropout=self.dropout_r)
        self.n_ap=layers.LayerNormalization(epsilon=1e-6)
        super().build(s)

    def call(self, inputs, training=None):
        iq,ap=inputs
        return (iq + self.a_iq(self.n_iq(iq),ap,ap,training=training),
                ap + self.a_ap(self.n_ap(ap),iq,iq,training=training))

    def get_config(self):
        cfg=super().get_config()
        cfg.update({"num_heads":self.num_heads,"key_dim":self.key_dim,
                    "dropout":self.dropout_r})
        return cfg


def build_snr_estimator(iq_input):
    """Lightweight SNR estimator. Operates on full 1024-step input but only uses GAP."""
    x=layers.Activation('relu')(layers.BatchNormalization()(
      layers.Conv1D(16,7,padding='same',use_bias=False)(iq_input)))
    x=layers.Activation('relu')(layers.BatchNormalization()(
      layers.Conv1D(16,5,padding='same',use_bias=False)(x)))
    x=layers.GlobalAveragePooling1D()(x)   # collapses 1024 → scalar per channel
    x=layers.Dense(32,activation='relu')(x)
    return layers.Dense(1,activation='sigmoid',name='snr_pred')(x)


@tf.keras.utils.register_keras_serializable()
class SNRAdaptiveGate(layers.Layer):
    def __init__(self, out_dim, **kwargs):
        super().__init__(**kwargs); self.out_dim=out_dim
        self.proj_iq=layers.Dense(out_dim,use_bias=False)
        self.proj_ap=layers.Dense(out_dim,use_bias=False)
        self.ln=layers.LayerNormalization(epsilon=1e-6)

    def call(self, inputs):
        iq,ap,alpha=inputs; at=alpha[:,None,:]
        return self.ln((1.0-at)*self.proj_iq(iq)+at*self.proj_ap(ap))

    def get_config(self):
        cfg=super().get_config(); cfg.update({"out_dim":self.out_dim}); return cfg


def channel_attention(x, reduction=4):
    ch=x.shape[-1]; gap=layers.GlobalAveragePooling1D()(x)
    attn=layers.Dense(ch//reduction,activation='relu')(gap)
    attn=layers.Dense(ch,activation='sigmoid')(attn)
    return x*attn[:,None,:]


@tf.keras.utils.register_keras_serializable()
class LearnedPositionEmbedding(layers.Layer):
    def __init__(self, max_len=128, **kwargs):
        super().__init__(**kwargs); self.max_len=max_len

    def build(self, s):
        self.pe=self.add_weight(name='pe',shape=(1,self.max_len,s[-1]),
                                 initializer='zeros',trainable=True)

    def call(self, x): return x+self.pe[:,:tf.shape(x)[1],:]

    def get_config(self):
        cfg=super().get_config(); cfg.update({"max_len":self.max_len}); return cfg


@tf.keras.utils.register_keras_serializable()
class WarmupCosineDecay(keras.optimizers.schedules.LearningRateSchedule):
    def __init__(self, warmup_steps, total_steps, peak_lr=3e-4, min_lr=1e-6, **kwargs):
        super().__init__(**kwargs)
        self.warmup_steps=float(warmup_steps); self.total_steps=float(total_steps)
        self.peak_lr=float(peak_lr); self.min_lr=float(min_lr)

    def __call__(self, step):
        step=tf.cast(step,tf.float32)
        warmup=self.peak_lr*step/self.warmup_steps
        progress=(step-self.warmup_steps)/(self.total_steps-self.warmup_steps)
        cosine=self.min_lr+(self.peak_lr-self.min_lr)*0.5*(
               1.0+tf.cos(np.pi*tf.minimum(progress,1.0)))
        return tf.where(step<self.warmup_steps,warmup,cosine)

    def get_config(self):
        return {"warmup_steps":self.warmup_steps,"total_steps":self.total_steps,
                "peak_lr":self.peak_lr,"min_lr":self.min_lr}


# ══════════════════════════════════════════════════════════════════════════════
# MAIN MODEL
# ══════════════════════════════════════════════════════════════════════════════
def build_model_v7_2018(n_classes=24, hoc_dim=10, seq_len=1024):
    """
    CORRECTED flow — compress BEFORE cross-attention:

    (B, 1024, 2)
    → ResBlocks [IQ complex, AP real] × 3     (B, 1024, C)
    → StridedConv stride=8                    (B,  128, C)   ← HERE
    → CrossStreamAttention × 3               (B,  128, C)   ← safe
    → SNRAdaptiveGate                         (B,  128, 160)
    → BiLSTM(128)                             (B,  128, 256)
    → ChannelAttn + GAP                       (B,  256)
    → HOC MLP                                 (B,   64)
    → Concat → Dense → softmax                (B,   24)
    """
    iq_input  = keras.Input(shape=(seq_len, 2),  name='iq_input')
    ap_input  = keras.Input(shape=(seq_len, 2),  name='ap_input')
    hoc_input = keras.Input(shape=(hoc_dim,),     name='hoc_input')

    # ── IQ stream ResBlocks (on full 1024) ────────────────────────────────────
    iq = layers.Dropout(0.05)(layers.Activation('gelu')(
         ComplexBatchNorm(name='iq_stem_bn')(
         ComplexConv1D(32,7,name='iq_stem')(iq_input))))
    iq = complex_res_block(iq, 32, 7)
    iq = complex_res_block(iq, 48, 5)
    iq = complex_res_block(iq, 48, 5)
    iq = layers.Dropout(0.1)(iq)              # (B, 1024, 96)

    # ── AP stream ResBlocks (on full 1024) ────────────────────────────────────
    ap = layers.Dropout(0.05)(layers.Activation('gelu')(
         layers.BatchNormalization()(
         layers.Conv1D(32,7,padding='same',use_bias=False,name='ap_stem')(ap_input))))
    ap = real_res_block(ap, 32, 7)
    ap = real_res_block(ap, 48, 5)
    ap = real_res_block(ap, 64, 5)
    ap = layers.Dropout(0.1)(ap)              # (B, 1024, 64)

    # ── Compress 1024 → 128 BEFORE cross-attention ───────────────────────────
    # stride=8: 1024/8 = 128. This is the OOM fix.
    # CrossAttn on 128 steps: [B,4,128,128] = 262K floats — fine.
    # CrossAttn on 1024 steps: [B,4,1024,1024] = 16M floats — OOM.
    iq = layers.Activation('gelu')(layers.BatchNormalization()(
         layers.Conv1D(96, 8, strides=8, padding='same',
                       use_bias=False, name='iq_compress')(iq)))   # (B, 128, 96)
    ap = layers.Activation('gelu')(layers.BatchNormalization()(
         layers.Conv1D(64, 8, strides=8, padding='same',
                       use_bias=False, name='ap_compress')(ap)))   # (B, 128, 64)

    # ── CrossStreamAttention × 3 (on 128 steps — safe) ───────────────────────
    iq, ap = CrossStreamAttention(4, 16, name='ca1')([iq, ap])
    iq, ap = CrossStreamAttention(4, 24, name='ca2')([iq, ap])
    iq, ap = CrossStreamAttention(4, 24, name='ca3')([iq, ap])

    # ── SNR-adaptive gate ─────────────────────────────────────────────────────
    snr_pred = build_snr_estimator(iq_input)   # reads from original 1024-step input
    fused = SNRAdaptiveGate(out_dim=160, name='snr_gate')([iq, ap, snr_pred])

    # ── Temporal modelling ────────────────────────────────────────────────────
    fused = LearnedPositionEmbedding(max_len=128, name='pos_emb')(fused)
    fused = layers.Bidirectional(
        layers.LSTM(128, return_sequences=True, dropout=0.1),
        name='bilstm')(fused)
    fused = channel_attention(fused, reduction=4)
    fused = layers.GlobalAveragePooling1D()(fused)
    fused = layers.LayerNormalization(epsilon=1e-6)(fused)

    # ── HOC branch ────────────────────────────────────────────────────────────
    hoc = layers.Dropout(0.2)(layers.BatchNormalization()(
          layers.Dense(32, activation='gelu')(hoc_input)))
    hoc = layers.Dropout(0.2)(layers.BatchNormalization()(
          layers.Dense(64, activation='gelu')(hoc)))

    # ── Classifier ────────────────────────────────────────────────────────────
    combined = layers.Concatenate(name='deep_hoc_fusion')([fused, hoc])
    combined = layers.Dropout(0.3)(
               layers.Dense(128, activation='gelu',
                            kernel_regularizer=keras.regularizers.l2(5e-5))(combined))
    cls_out = layers.Dense(n_classes, activation='softmax',
                            dtype='float32', name='output')(combined)

    return keras.Model([iq_input, ap_input, hoc_input], [cls_out, snr_pred],
                       name='RadioML_v7_2018')


